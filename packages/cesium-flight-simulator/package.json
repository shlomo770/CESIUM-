{
  "name": "@cesium-suite/cesium-flight-simulator",
  "version": "1.0.0",
  "description": "Integrable Cesium globe flight simulator with map tiles, GLTF aircraft, HUD, and external telemetry",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-styles.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cesium",
    "flight-simulator",
    "react",
    "telemetry",
    "gltf",
    "map-tiles"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "cesium": "^1.110.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-redux": "^9.0.0"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.2.7",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "cesium": "^1.120.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  }
}
